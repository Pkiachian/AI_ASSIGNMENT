        "outputId": "1a87bac9-499a-4e02-dc43-fb6c0c57836a"
      },
      "source": [
        "def get_result(row):\n",
        "    if row['home_score'] > row['away_score']:\n",
        "        return 'Home Win'\n",
        "    elif row['away_score'] > row['home_score']:\n",
        "        return 'Away Win'\n",
        "    else:\n",
        "        return 'Draw'\n",
        "\n",
        "# Apply the function to create the 'result' column\n",
